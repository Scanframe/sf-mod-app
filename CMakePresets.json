{
	"version": 3,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 22,
		"patch": 0
	},
	"configurePresets": [
		{
			"hidden": true,
			"name": ".cfg",
			"displayName": "Linux Configure Template",
			"description": "Configure template for Linux.",
			"generator": "Ninja",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_COLOR_DIAGNOSTICS": "ON",
				"SF_BUILD_QT": "OFF"
			},
			"environment": {
				"PATH": "$env{HOME}/cmake/lib/bin:$penv{PATH}"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		},
		{
			"hidden": true,
			"inherits": [
				".cfg"
			],
			"name": ".cfg-qt",
			"displayName": "Linux QT Configure Template",
			"description": "Configure template for Linux using QT.",
			"generator": "Ninja",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_COLOR_DIAGNOSTICS": "ON",
				"SF_BUILD_QT": "ON"
			},
			"environment": {
				"PATH": "${sourceDir}/cmake/lib/bin:$penv{PATH}"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		},
		{
			"inherits": [
				".cfg-qt"
			],
			"name": "gnu-debug",
			"displayName": "GNU-Debug",
			"description": "Configuration to build qt-app using Linux GNU compiler.",
			"cacheVariables": {
				"SF_BUILD_TESTING": "ON",
				"SF_TARGET_SYSTEM": "Linux",
				"SF_CROSS_WINDOWS": "OFF"
			},
			"binaryDir": "${sourceDir}/cmake-build/qt-gnu-debug"
		},
		{
			"name": "gw-debug",
			"displayName": "GW-Debug",
			"description": "Configuration to build qt-app using Linux GNU cross compiler.",
			"cacheVariables": {
				"SF_BUILD_TESTING": "OFF",
				"SF_TARGET_SYSTEM": "Windows",
				"SF_CROSS_WINDOWS": "ON"
			},
			"inherits": [
				".cfg-qt"
			],
			"binaryDir": "${sourceDir}/cmake-build/qt-gw-debug"
		},
		{
			"name": "mingw-debug",
			"displayName": "MinGW-Debug",
			"description": "Configuration to build qt-app using Windows MinGW compiler.",
			"cacheVariables": {
				"SF_BUILD_TESTING": "OFF",
				"SF_TARGET_SYSTEM": "Windows",
				"SF_CROSS_WINDOWS": "OFF"
			},
			"inherits": [
				".cfg-qt"
			],
			"binaryDir": "${sourceDir}/cmake-build/qt-mingw-debug",
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		}
	],
	"buildPresets": [
		{
			"name": ".build",
			"hidden": true,
			"cleanFirst": false,
			"verbose": false,
			"jobs": 8,
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		},
		{
			"name": "gnu-debug",
			"displayName": "GNU-Debug",
			"description": "QT Application build using GNU toolchain.",
			"inherits": [
				".build"
			],
			"configurePreset": "gnu-debug",
			"targets": [
				"all"
			]
		},
		{
			"name": "gw-debug",
			"displayName": "GW-Debug",
			"description": "QT Application build using GW toolchain.",
			"inherits": [
				".build"
			],
			"configurePreset": "gw-debug",
			"targets": [
				"all"
			]
		},
		{
			"name": "mingw-debug",
			"displayName": "MinGW-Debug",
			"description": "QT Application build using MinGW toolchain.",
			"inherits": [
				".build"
			],
			"configurePreset": "mingw-debug",
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		}
	],
	"testPresets": [
		{
			"name": "gnu-debug",
			"hidden": false,
			"displayName": "GNU-Debug",
			"description": "QT Test build using GNU toolchain.",
			"configurePreset": "gnu-debug",
			"output": {
				"outputOnFailure": true
			},
			"execution": {
				"noTestsAction": "error",
				"stopOnFailure": true
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		},
		{
			"name": "gw-debug",
			"hidden": false,
			"displayName": "GW-Debug",
			"description": "QT Test build using GW toolchain.",
			"configurePreset": "gw-debug",
			"output": {
				"outputOnFailure": true,
				"shortProgress": true,
				"verbosity": "extra"
			},
			"execution": {
				"noTestsAction": "error",
				"stopOnFailure": true
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		},
		{
			"name": "mingw-debug",
			"hidden": false,
			"displayName": "MinGW-Debug",
			"description": "QT Test build using MinGW toolchain.",
			"configurePreset": "mingw-debug",
			"output": {
				"outputOnFailure": true
			},
			"execution": {
				"noTestsAction": "error",
				"stopOnFailure": true
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		}
	]
}
